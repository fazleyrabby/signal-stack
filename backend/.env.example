# --- Database ---
DATABASE_URL="postgresql://signal:signal@localhost:5433/signalstack"

# --- Security ---
ADMIN_API_KEY="dev-admin-key"

# --- AI Intelligence Tier (Phase 3) ---
# For Groq (Recommended for Speed):
# AI_API_URL="https://api.groq.com/openai/v1/chat/completions"
# AI_API_KEY="your-groq-api-key"
# AI_MODEL="llama-3.3-70b-versatile"

# For OpenRouter:
# AI_API_URL="https://openrouter.ai/api/v1/chat/completions"
# AI_API_KEY="your-openrouter-api-key"
# AI_MODEL="meta-llama/llama-3.1-405b-instruct"

# --- Alerts ---
DISCORD_WEBHOOK_URL="your-discord-webhook-url"
DISCORD_FILTER_TECH="true"
DISCORD_ALERT_CATEGORIES=technology  # comma-separated, e.g. technology,geopolitics

# --- Data Retention ---
SIGNAL_RETENTION_DAYS=90

# --- Misc ---
PORT=3000
NODE_ENV=development
